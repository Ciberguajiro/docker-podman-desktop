{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "docker-podman-desktop",
    "version": "1.0.27",
    "identifier": "com.ciberguajiro.docker-podman-desktop",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../build"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "docker-podman-desktop",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' asset: https:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' asset: ipc.localhost;"
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5QjRBREM3QUQxNTA5RDMKUldUVENSV3R4NjIweVdVRHVFaUx5bVRpTlNxNHdXMHpNTk9YYnF1U1M5OGFNTENjZFJxVHZnUi8K"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "publisher": "Ciberguajiro",
        "category": "DeveloperTool",
        "linux": {
            "deb": {
                "depends": [
                    "webkit2gtk-4.0",
                    "libgtk-3-0",
                    "libayatana-appindicator3-1"
                ]
            }
        },
        "windows": {
            "wix": {
                "language": "en-US"
            },
            "nsis": {
                "languages": [
                    "English",
                    "Spanish"
                ]
            }
        }
    }
}
